#!/usr/bin/env bash

read -p "Enter the ip address: " ipadd

# Basic IPv4 format validation
if [[ $ipadd =~ ^[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}$ ]]; then
  # Ping to ensure the host is awake and populate the ARP cache
  if ping -c 1 -W 1 "$ipadd" >/dev/null 2>&1; then
    # Use command substitution $() to execute the command
    # awk is used to extract only the MAC address from the output
    mac=$(ip neighbor show "$ipadd" | awk '{print $5}')

    if [[ -n $mac && $mac != "FAILED" ]]; then
      echo "$ipadd ==== $mac"
    else
      echo "No MAC address found for $ipadd."
    fi
  else
    echo "Host $ipadd is unreachable."
  fi
else
  echo "Invalid IP address format. Please enter a valid IPv4 address."
fi
