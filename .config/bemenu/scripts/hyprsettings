#!/usr/bin/env bash
set -euo pipefail

MENU_ITEMS=(
  "Blur|blur"
  "Decoration|decoration"
  "Fullscreen|fullscreen"
  "Master|master"
  "Dwindle|dwindle"
  "Scrolling|scrolling"
  "Monocle|monocle"
  "Opacity 1.0|opacity_10"
  "Opacity 0.95|opacity_9"
  "Opacity 0.1|opacity_1"
)

blur() {
  state=$(hyprctl getprop activewindow no_blur)
  if [ "$state" = "false" ]; then
    hyprctl dispatch 'hl.dsp.window.set_prop({prop="no_blur",value="1",window="activewindow"})'
  else
    hyprctl dispatch 'hl.dsp.window.set_prop({prop="no_blur",value="0",window="activewindow"})'
  fi
}

decoration() {
  state=$(hyprctl getprop activewindow decorate)
  if [ "$state" = "false" ]; then
    hyprctl dispatch 'hl.dsp.window.set_prop({prop="decorate",value="1",window="activewindow"})'
  else
    hyprctl dispatch 'hl.dsp.window.set_prop({prop="decorate",value="0",window="activewindow"})'
  fi
}

fullscreen() {
  hyprctl dispatch 'hl.dsp.window.fullscreen({mode="fullscreen",window="activewindow"})'
}

master() {
  hyprctl eval 'hl.config({general = {layout="master"}})'
}

dwindle() {
  hyprctl eval 'hl.config({general = {layout="dwindle"}})'
}

scrolling() {
  hyprctl eval 'hl.config({general = {layout="scrolling"}})'
}

monocle() {
  hyprctl eval 'hl.config({general = {layout="monocle"}})'
}

opacity_10() {
  hyprctl dispatch 'hl.dsp.window.set_prop({prop="opacity",value="1",window="activewindow"})'
}
opacity_9() {
  hyprctl dispatch 'hl.dsp.window.set_prop({prop="opacity",value="0.95",window="activewindow"})'
}
opacity_1() {
  hyprctl dispatch 'hl.dsp.window.set_prop({prop="opacity",value="0.1",window="activewindow"})'
}

CHOICE=$(for item in "${MENU_ITEMS[@]}"; do
  IFS="|" read -r label _ <<<"$item"
  echo "$label"
done | bmenu "Rules")

for item in "${MENU_ITEMS[@]}"; do
  IFS="|" read -r label func <<<"$item"
  if [[ "$CHOICE" == "$label" ]]; then
    "$func"
    exit 0
  fi
done

exit 1
