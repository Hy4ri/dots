#!/usr/bin/env bash
# sendkey — send keyboard/mouse events to Hyprland windows
#
# A bash library that wraps the sendkey.lua module via hyprctl eval.
# Requires sendkey.lua to be loaded in hyprland.conf:
#   dofile(os.getenv("HOME") .. "/.config/hypr/scripts/sendkey.lua")
#
# Designed to be sourced from automation scripts.
#
# ── How it works ──────────────────────────────────────────────────────
#
# All functions delegate to the sendkey Lua module running inside Hyprland:
#
#   hyprctl eval 'sendkey.key({window="class:foot", key="ctrl+c"})'
#
# repeat_key and hold use hl.timer() inside Hyprland's event loop —
# zero hyprctl overhead during the loop. One eval call to start,
# one to stop.
#
# The window parameter accepts the same selectors hyprctl uses:
#   - "class:foot"           Match by window class
#   - "title:Firefox"        Match by window title
#   - "address:0x1337"       Match by window address
#   - "foot"                 Shorthand for class:foot
#   - "activewindow"         Currently focused window
#   - "floating" / "tiled"   Match by window state
#
# ── Setup ─────────────────────────────────────────────────────────────
#
# Add to your hyprland.conf Lua config block:
#
#   dofile(os.getenv("HOME") .. "/.config/hypr/scripts/sendkey.lua")
#
# Then reload: hyprctl reload
#
# ── Usage ─────────────────────────────────────────────────────────────
#
#   source ~/.config/hypr/scripts/sendkey
#
#   # Single keypress
#   key "foot" "ctrl+c"               # Send Ctrl+C to foot terminal
#   key "title:Firefox" "f5"          # Send F5 to Firefox
#   key "class:Code" "ctrl+shift+p"   # Open command palette in VSCode
#
#   # Shortcut (single dispatch keypress via send_shortcut)
#   shortcut "foot" "ctrl+c"          # Send Ctrl+C via send_shortcut
#   shortcut "foot" "ctrl+shift+v"    # Paste in foot
#
#   # Repeat a key (toggle on/off, or N times)
#   repeat_key "foot" "y"             # Toggle infinite 'y' repeat
#   repeat_key "foot" "ctrl+v" 5      # Paste 5 times (auto-stops)
#
#   # Hold a key down (toggle on/off via hl.timer)
#   hold "foot" "w"                   # Hold 'w' (walk forward)
#   hold "firefox" "ctrl+tab"         # Hold tab-forward
#
#   # Mouse actions
#   click "firefox" "left" 500 300    # Left-click at x=500 y=300
#   click "class:Code" "ctrl+left" 100 200  # Ctrl+left-click
#   mouse 800 600                     # Move cursor
#
#   # Scrolling (page up/down)
#   scroll "foot" "down" 3            # Page-down 3 times
#   scroll "firefox" "up"             # Page-up once
#
#   # Window management
#   focus "foot"                      # Focus a window
#   focus "title:Firefox"             # Focus Firefox by title
#
#   # Cleanup active timers
#   cleanup
#
# ── Environment variables ─────────────────────────────────────────────
#
#   SK_NO_NOTIFY  Set to 1 to suppress notifications
#   SK_VERBOSE    Set to 1 to log hyprctl errors to stderr
#   SK_LUA_PATH   Path to sendkey.lua if not at default location
#
# ── Internal helpers ──────────────────────────────────────────────────

_sk_eval() {
  hyprctl -q eval "$@" 2>/dev/null
  local rc=$?
  if [[ $rc -ne 0 && -n "${SK_VERBOSE:-}" ]]; then
    echo "sk: eval failed ($rc): $*" >&2
  fi
}

_sk_notify() {
  [[ -n "${SK_NO_NOTIFY:-}" ]] && return
  hyprctl -q notify -1 2000 "rgb(66ee66)" "$*" 2>/dev/null || true
}

# ── Public API ─────────────────────────────────────────────────────────

mouse() {
  local cord_x="${1:?Missing X coordinate}"
  local cord_y="${2:?Missing Y coordinate}"
  _sk_eval 'sendkey.mouse({x='$cord_x',y='$cord_y'})'
}

click() {
  local class="${1:?Missing window class}"
  local key_input="${2:?Missing key/button}"
  local cord_x="${3:?Missing X coordinate}"
  local cord_y="${4:?Missing Y coordinate}"
  _sk_eval 'sendkey.click({window="'"$class"'",button="'"$key_input"'",x='$cord_x',y='$cord_y'})'
}

key() {
  local class="${1:?Missing window class}"
  local key_input="${2:?Missing key}"
  _sk_eval 'sendkey.key({window="'"$class"'",key="'"$key_input"'"})'
}

shortcut() {
  local class="${1:?Missing window class}"
  local key_input="${2:?Missing key}"
  _sk_eval 'sendkey.shortcut({window="'"$class"'",key="'"$key_input"'"})'
}

focus() {
  local class="${1:?Missing window class}"
  _sk_eval 'sendkey.focus({window="'"$class"'"})'
}

repeat_key() {
  local class="${1:?Missing window class}"
  local key_input="${2:?Missing key}"
  local count="${3:-0}"
  _sk_eval 'sendkey.repeat({window="'"$class"'",key="'"$key_input"'",count='$count'})'
}

hold() {
  local class="${1:?Missing window class}"
  local key_input="${2:?Missing key}"
  _sk_eval 'sendkey.hold({window="'"$class"'",key="'"$key_input"'"})'
}

scroll() {
  local class="${1:?Missing window class}"
  local direction="${2:?Missing direction (up/down)}"
  local amount="${3:-1}"
  _sk_eval 'sendkey.scroll({window="'"$class"'",direction="'"$direction"'",amount='$amount'})'
}

cleanup() {
  _sk_eval 'sendkey.cleanup()'
}